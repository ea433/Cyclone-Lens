@using Presentation.Models

@model List<ObservatieViewModel>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<h1>Observaties</h1>

<p>Bekijk en rapporteer meteorologische observaties</p>

<table class="table">

    <thead>
        <tr>
            <th>ID</th>
            <th>Ingediend door</th>
            <th>Datum</th>
            <th>Actie</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var observatie in Model)
        {
            <tr>

                <td>
                    @observatie.Id
                </td>

                <td>
                    @observatie.Inzender
                </td>

                <td>
                    @observatie.Tijdstip.ToString("yyyy-MM-dd HH:mm")
                </td>

                <td>

                    <a class="btn btn-primary"
                       href="/Observatie/Details/@observatie.Id">

                        Bekijken

                    </a>

                    <br />
                    <br />

                    <form asp-action="Rapporteer"
                          asp-controller="Observatie"
                          method="post">

                        <input type="hidden"
                               name="observatieId"
                               value="@observatie.Id" />

                        <button type="submit"
                                class="btn btn-outline-dark"
                                onclick="return confirm('Weet je zeker dat je deze observatie wilt rapporteren?')">

                            Rapporteer

                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>