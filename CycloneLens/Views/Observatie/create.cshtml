@model Presentation.Models.ObservatieViewModel

<div class="form-container">

    @section Styles {
        <link rel="stylesheet"
              href="~/css/ObservatieCreate.css"
              asp-append-version="true" />
    }

    <!-- Header box -->
    <div class="box">
        <div class="box-title">Observatie toevoegen</div>
        <div class="box-subtitle">Vul uw waarnemingen in</div>
    </div>

    <!-- Form box -->
    <div class="box">
        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="CycloonId" />

            <!-- Latitude -->
            <label>Latitude *</label>

            <input asp-for="Latitude"
                   type="number"
                   step="any"
                   min="-90"
                   max="90"
                   required
                   placeholder="bijv. 23.5" />

            <span asp-validation-for="Latitude"
                  class="text-danger"></span>

            <!-- Longitude -->
            <label>Longitude *</label>

            <input asp-for="Longitude"
                   type="number"
                   step="any"
                   min="-180"
                   max="180"
                   required
                   placeholder="bijv. -65.2" />

            <span asp-validation-for="Longitude"
                  class="text-danger"></span>

            <!-- Description -->
            <label>Beschrijving *</label>

            <textarea asp-for="Omschrijving"
                      required
                      minlength="10"
                      placeholder="Beschrijf uw waarneming..."></textarea>

            <span asp-validation-for="Omschrijving"
                  class="text-danger"></span>

            <!-- Submit -->
            <button type="submit" class="submit-btn">
                Observatie versturen
            </button>

        </form>
    </div>
</div>