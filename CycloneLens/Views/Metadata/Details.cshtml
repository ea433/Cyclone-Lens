<h2>@Model.Item1.Naam</h2>
<p>@Model.Item1.Bassin.ToString().Replace("_", " ")</p>

<a asp-controller="Cycloon" asp-action="Edit" asp-route-id="@Model.Item1.Id" class="btn btn-primary">
    Bewerken
</a>

<h3>Traject en Cycloondata</h3>

<table class="table">
    <thead>
        <tr>
            <th>Categorie</th>
            <th>Windsnelheid</th>
            <th>Coordinaten</th>
            <th>Tijdstip</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model.Item2)
        {
            <tr>
                <td>@m.Categorie.ToString().Replace("_", " ")</td>
                <td>@m.Windsnelheid km/u</td>
                <td>@m.Coordinaten</td>
                <td>@m.Tijdstip</td>
            </tr>
        }
    </tbody>
</table>