@using Microsoft.AspNetCore.Http
<h2>@Model.Naam</h2>
<p>@Model.Bassin.ToString().Replace("_", " ")</p>
@if ((Context.Session.GetInt32("UserType") ?? 0) == 3)
{
    <a asp-controller="Cycloon"
       asp-action="Edit"
       asp-route-id="@Model.Id"
       class="btn btn-primary">
        Bewerken
    </a>
}

<h3>Traject en Cycloondata</h3>

<table class="table">
    <thead>
        <tr>
            <th>Categorie</th>
            <th>Windsnelheid</th>
            <th>Coordinaten</th>
            <th>Tijdstip</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var m in Model.Metadata)
        {
            <tr>
                <td>@m.Categorie.ToString().Replace("_", " ")</td>
                <td>@m.Windsnelheid km/u</td>
                <td>@m.Coordinaten</td>
                <td>@m.Tijdstip</td>
            </tr>
        }
    </tbody>
</table>