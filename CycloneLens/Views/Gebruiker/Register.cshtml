@model Presentation.Models.GebruikerViewModel

<div class="auth-container">
    <h1>Account Aanmaken</h1>

    @if (ViewBag.Fout != null)
    {
        <p class="fout">@ViewBag.Fout</p>
    }

    <div class="form-group">
        <label asp-for="Gebruikersnaam">Gebruikersnaam</label>
        <input asp-for="Gebruikersnaam" placeholder="gebruikersnaam" />
    </div>

    <div class="form-group">
        <label asp-for="Wachtwoord">Wachtwoord</label>
        <input asp-for="Wachtwoord" type="password" placeholder="••••••••••" />
    </div>

    <button type="button" onclick="submitRegister()">Account Aanmaken</button>
</div>

<script>
    function submitRegister() {
        document.querySelector('form')?.submit();
    }
</script>