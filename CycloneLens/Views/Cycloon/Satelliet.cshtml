@section Scripts {
    <script src="~/js/satelliet.js"
            asp-append-version="true"></script>
}

@section Styles {
    <link rel="stylesheet"
          href="~/css/satelliet.css"
          asp-append-version="true" />
}

<div class="container mt-4">

    <div class="card shadow-sm mb-4">

        <div class="card-body">

            <label class="form-label">
                Selecteer cycloon
            </label>

            <select class="form-select">
            </select>

        </div>
    </div>

    <div class="card shadow-sm mb-4">

        <div class="card-body">

            <h5 class="card-title">
                Satellietbeeld
            </h5>

            <p class="text-muted small">
                Bron: NOAA GOES
            </p>

            <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                 style="height: 750px; overflow: hidden;">

                <img id="goesImage"
                     style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" />

            </div>

            <div class="mt-3 text-center">

                <button class="btn btn-outline-primary btn-sm me-2"
                        onclick="setSat('GEOCOLOR')">
                    GeoColor
                </button>

                <button class="btn btn-outline-primary btn-sm me-2"
                        onclick="setSat('AIR_MASS')">
                    Luchtmassa
                </button>

                <button class="btn btn-outline-primary btn-sm"
                        onclick="setSat('SHORTWAVE_IR')">
                    SWIR
                </button>

            </div>

            <div class="mt-3 border-top pt-3">

                <p class="text-muted small">
                    Databron: NOAA (National Oceanic and Atmospheric Administration)
                </p>

                <small id="time" class="text-muted"></small>

            </div>

        </div>
    </div>
</div>