@model List<Presentation.Models.CycloonViewModel>
<h2>Actieve Cyclonen - Noord-Atlantisch Bassin</h2>
<table class="table">
    <thead>
        <tr>
            <th>Naam</th>
            <th>Categorie</th>
            <th>Bassin</th>
            <th>Status</th>
            @if ((Context.Session.GetInt32("UserType") ?? 0) < 1)
            {
                <th>Observaties</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var cycloon in Model)
        {
            <tr>
                <td>
                    <a asp-controller="Metadata" asp-action="Details" asp-route-id="@cycloon.Id">
                        @cycloon.Naam
                    </a>
                </td>
                <td>@cycloon.Categorie.ToString().Replace("_", " ")</td>
                <td>@cycloon.Bassin.ToString().Replace("_", " ")</td>
                <td>@cycloon.Status.ToString().Replace("_", " ")</td>
                @if ((Context.Session.GetInt32("UserType") ?? 0) >= 1)
                {
                    <td>
                        <a asp-controller="Observatie"
                           asp-action="Create"
                           asp-route-cycloonId="@cycloon.Id"
                           class="btn btn-sm btn-primary">
                            + Observatie
                        </a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>