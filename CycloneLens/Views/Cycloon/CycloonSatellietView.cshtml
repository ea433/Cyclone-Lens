@section Scripts {
    <script>
        function updateGOES() {
            const img = document.getElementById("goesImage");

            if (!img) return;

            const timestamp = new Date().getTime();

            img.src = `https://cdn.star.nesdis.noaa.gov/GOES19/ABI/SECTOR/taw/GEOCOLOR/latest.jpg?t=${timestamp}`;
        }

        // run immediately
        updateGOES();

        // refresh every 10 minutes
        setInterval(updateGOES, 600000);
    </script>
}


<div class="container mt-4">

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <label class="form-label">Selecteer cycloon</label>
            <select class="form-select">
                <option>Cycloon Maria (2023)</option>
            </select>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h5 class="card-title"> Satellietbeeld</h5>
            <p class="text-muted small">Bron: NOAA GOES-16</p>

            <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                 style="height: 300px; overflow: hidden;">

                <img id="goesImage"
                     style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" />

            </div>

            <div class="mt-3 border-top pt-3">
                <p>  Tijdstip: <span id="time"></span></p>
                <p>  Locatie: <span id="location"></span></p>
                <p class="text-muted small">Databron: NOAA / NASA</p>
            </div>

        </div>
    </div>

    <div class="text-muted small text-center">
        Data via publieke API’s (NOAA, NASA, NHC)
    </div>

</div>