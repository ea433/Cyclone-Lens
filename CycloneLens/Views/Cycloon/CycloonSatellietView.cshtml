@section Scripts {
    <script>
        function updateGOES() {
            const img = document.getElementById("goesImage");

            if (!img) return;

            const timestamp = new Date().getTime();

            img.src = `https://cdn.star.nesdis.noaa.gov/GOES19/ABI/SECTOR/taw/GEOCOLOR/latest.jpg?t=${timestamp}`;
        }

        // run immediately
        updateGOES();

        // refresh every 10 minutes
        setInterval(updateGOES, 600000);
    </script>
}


<div class="container mt-4">

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <label class="form-label">Selecteer cycloon</label>
            <select class="form-select">
            </select>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h5 class="card-title"> Satellietbeeld</h5>
            <p class="text-muted small">Bron: NOAA GOES-16</p>

            <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                 style="height: 300px; overflow: hidden;">

                <img id="goesImage"
                     style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" />

            </div>

            <div class="mt-3 border-top pt-3">
                <p>  Tijdstip: <span id="time"></span></p>
                <p>  Locatie: <span id="location"></span></p>
                <p class="text-muted small">Databron: NOAA (National Oceanic and Atmospheric Administration)</p>
            </div>

        </div>
    </div>

</div>

<div class="sat-container">
    <img id="satImage" src="GEOCOLOR_URL" alt="Satellite image">

    <div class="sat-buttons">
        <button onclick="setSat('GEOCOLOR')">GeoColor</button>
        <button onclick="setSat('AIR_MASS')">Air Mass</button>
        <button onclick="setSat('SHORTWAVE_IR')">Shortwave IR</button>
    </div>
</div>

<div>
    <script>
        const baseUrl = "https://your-goes-source/";

        const products = {
          GEOCOLOR: "geocolor.jpg",
          AIR_MASS: "airmass.jpg",
          DUST_RGB: "dust.jpg",
          FIRE_TEMPERATURE: "fire.jpg"
        };

        let currentProduct = "GEOCOLOR";

        function setSat(product) {
          currentProduct = product;
          updateImage();
        }

        function updateImage() {
          const img = document.getElementById("satImage");

          // cache buster so browser doesn't reuse old image
          const timestamp = new Date().getTime();

          img.src = baseUrl + products[currentProduct] + "?t=" + timestamp;
        }

        // refresh every 60 seconds
        setInterval(updateImage, 60000);

        // initial load
        updateImage();
    </script>
</div>