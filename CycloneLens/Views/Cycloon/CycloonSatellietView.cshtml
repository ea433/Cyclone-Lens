@section Scripts {
    <script>
        const sources = {
            GEOCOLOR: "https://cdn.star.nesdis.noaa.gov/GOES16/ABI/SECTOR/taw/GEOCOLOR/latest.jpg",
            AIR_MASS: "https://cdn.star.nesdis.noaa.gov/GOES19/ABI/SECTOR/taw/AirMass/20261061630_GOES19-ABI-taw-AirMass-3600x2160.jpg",
            SHORTWAVE_IR: "https://cdn.star.nesdis.noaa.gov/GOES19/ABI/SECTOR/taw/07/20261062100_GOES19-ABI-taw-07-3600x2160.jpg"
        };

        let currentProduct = "GEOCOLOR";

        function updateGOES() {
            const img = document.getElementById("goesImage");
            if (!img) return;

            const timestamp = new Date().getTime();
            img.src = sources[currentProduct] + "?t=" + timestamp;
        }

        function setSat(product) {
            currentProduct = product;
            updateGOES();
        }

        // initial load
        updateGOES();

        // refresh every 10 minutes
        setInterval(updateGOES, 600000);
    </script>
}


<div class="container mt-4">

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <label class="form-label">Selecteer cycloon</label>
            <select class="form-select">
            </select>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h5 class="card-title">Satellietbeeld</h5>
            <p class="text-muted small">Bron: NOAA GOES-16</p>

            <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                 style="height: 750px; overflow: hidden;">

                <img id="goesImage"
                     style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" />

            </div>

            <!-- Buttons moved here -->
            <div class="mt-3 text-center">
                <button class="btn btn-outline-primary btn-sm me-2" onclick="setSat('GEOCOLOR')">GeoColor</button>
                <button class="btn btn-outline-primary btn-sm me-2" onclick="setSat('AIR_MASS')">Air Mass</button>
                <button class="btn btn-outline-primary btn-sm" onclick="setSat('SHORTWAVE_IR')">Shortwave IR</button>
            </div>

            <div class="mt-3 border-top pt-3">
                <p>Tijdstip: <span id="time"></span></p>
                <p>Locatie: <span id="location"></span></p>
                <p class="text-muted small">Databron: NOAA (National Oceanic and Atmospheric Administration)</p>
            </div>

        </div>
    </div>

</div>